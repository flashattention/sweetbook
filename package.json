{
	"name": "momento-photobook",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"db:backup": "node scripts/backup-db.js",
		"db:backup:auto:install": "zsh scripts/install-db-backup-launchd.sh",
		"db:backup:auto:uninstall": "zsh scripts/uninstall-db-backup-launchd.sh",
		"db:backup:auto:status": "launchctl list | grep com.sweetbook.dbbackup || true",
		"db:setup:safe": "npm run db:backup && prisma db push && node prisma/seed.js",
		"db:setup": "prisma db push && node prisma/seed.js",
		"db:seed": "node prisma/seed.js",
		"db:reset": "prisma db push --force-reset && node prisma/seed.js",
		"smoke-test": "node scripts/smoke-test.js",
		"probe-templates": "node scripts/probe-templates.js"
	},
	"dependencies": {
		"@prisma/client": "^5.14.0",
		"dotenv": "^16.0.0",
		"next": "14.2.3",
		"openai": "^4.91.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"uuid": "^9.0.1"
	},
	"devDependencies": {
		"@types/node": "^20.12.7",
		"@types/react": "^18.3.1",
		"@types/react-dom": "^18.3.0",
		"@types/uuid": "^9.0.8",
		"autoprefixer": "^10.4.19",
		"postcss": "^8.4.38",
		"prisma": "^5.14.0",
		"tailwindcss": "^3.4.3",
		"typescript": "^5.4.5"
	},
	"prisma": {
		"seed": "node prisma/seed.js"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"license": "MIT"
}
