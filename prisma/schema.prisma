// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title           String
  storyCharacters String?
  requestedPageCount Int?
  generationStage String?
  generationProgress Int?
  generationError String?
  generationCostUsd Float?
  projectType String  @default("PHOTOBOOK")
  genre       String?
  synopsis    String?
  comicStyle  String?
  // 만화책 생성 시 캐릭터 참조 이미지 [{name, imageUrl}] (JSON)
  characterImagesJson String?

  bookSpecUid          String  @default("SQUAREBOOK_HC")
  coverTemplateUid     String?
  contentTemplateUid   String?
  coverTemplateOverrides String?
  contentTemplateOverrides String?

  // Cover data (stored locally, used when building book)
  coverImageUrl  String?
  coverCaption   String? @default("")

  // Sweetbook API state
  bookUid      String?
  orderUid     String?
  orderStatus  String?
  trackingInfo String?

  // App state: DRAFT | PUBLISHED | ORDERED
  status String @default("DRAFT")

  // Default/demo project visible to all users
  isDefault Boolean @default(false)

  pages Page[]
  post  Post?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  emailVerified Boolean  @default(false)

  projects     Project[]
  posts        Post[]
  postLikes    PostLike[]
  comments     Comment[]
  commentLikes CommentLike[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Post {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description   String?
  projectType   String   // COMIC | NOVEL

  likes         PostLike[]
  comments      Comment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
  @@index([userId])
}

model PostLike {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Comment {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId   String
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId String?
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("Replies")
  content  String

  likes    CommentLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([parentId])
}

model CommentLike {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}

model Page {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  pageOrder Int
  imageUrl  String
  caption   String @default("")
  contentTemplateUid String?
  contentTemplateOverrides String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
