// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title           String
  storyCharacters String?
  requestedPageCount Int?
  generationStage String?
  generationProgress Int?
  generationError String?
  generationCostUsd Float?
  projectType String  @default("PHOTOBOOK")
  genre       String?
  synopsis    String?
  comicStyle  String?

  bookSpecUid          String  @default("SQUAREBOOK_HC")
  coverTemplateUid     String?
  contentTemplateUid   String?
  coverTemplateOverrides String?
  contentTemplateOverrides String?

  // Cover data (stored locally, used when building book)
  coverImageUrl  String?
  coverCaption   String? @default("")

  // Sweetbook API state
  bookUid      String?
  orderUid     String?
  orderStatus  String?
  trackingInfo String?

  // App state: DRAFT | PUBLISHED | ORDERED
  status String @default("DRAFT")

  // Default/demo project visible to all users
  isDefault Boolean @default(false)

  pages Page[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?

  projects     Project[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Page {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  pageOrder Int
  imageUrl  String
  caption   String @default("")
  contentTemplateUid String?
  contentTemplateOverrides String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}
