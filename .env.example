# Sweetbook Book Print API
SWEETBOOK_API_KEY=SB_YOUR_API_KEY
SWEETBOOK_ENV=sandbox
SWEETBOOK_WEBHOOK_SECRET=your_webhook_secret

# Optional default template UIDs (fallback when project-level template is empty)
SWEETBOOK_COVER_TEMPLATE_UID=39kySqmyRhhs
SWEETBOOK_CONTENT_TEMPLATE_UID=46VqZhVNOfAp

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# OpenAI (AI 생성기)
OPENAI_API_KEY=your_openai_api_key

# 크레딧 무료 충전용 관리자 암호 (미설정 시 "Test1234!" 사용 — 프로덕션에서는 반드시 변경)
ADMIN_CHARGE_PASSWORD=your_admin_password

# Auth (required in production)
AUTH_SECRET=replace_with_random_secret_min_16_chars

# Optional fallback used by lib/auth.ts
NEXTAUTH_SECRET=

# Optional app URLs used when resolving relative image URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Optional probe script setting
PROBE_BOOK_SPEC=SQUAREBOOK_HC
